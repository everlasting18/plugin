---
---

<section id="pricing" class="section" style="background: var(--gray-50);">
  <div class="container">
    <h2 class="section-title">Bảng giá đơn giản</h2>
    <p class="section-desc">
      Không phức tạp. Chọn gói phù hợp và bắt đầu viết bài ngay hôm nay.
    </p>

    <div class="pricing-grid">
      <!-- Free -->
      <div class="pricing-card">
        <div class="pricing-header">
          <h3>Miễn phí</h3>
          <div class="price">
            <span class="amount">0đ</span>
            <span class="period">/tháng</span>
          </div>
          <p class="pricing-desc">Dành cho người mới bắt đầu</p>
        </div>
        <ul class="pricing-features">
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M5 13l4 4L19 7" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            5 bài viết/tháng
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M5 13l4 4L19 7" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            8 framework viết bài
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M5 13l4 4L19 7" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Tạo meta SEO
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M5 13l4 4L19 7" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Viết lại đoạn văn
          </li>
          <li class="disabled">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M6 18L18 6M6 6l12 12" stroke="#9ca3af" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Không giới hạn
          </li>
        </ul>
        <a href="/login" class="btn btn-secondary" style="width: 100%; justify-content: center;">
          Bắt đầu miễn phí
        </a>
      </div>

      <!-- Pro -->
      <div class="pricing-card pricing-pro">
        <div class="pricing-badge">Phổ biến nhất</div>
        <div class="pricing-header">
          <h3>Pro</h3>
          <div class="price">
            <span class="amount">199.000đ</span>
            <span class="period">/tháng</span>
          </div>
          <p class="pricing-desc">Dành cho người viết nội dung chuyên nghiệp</p>
        </div>
        <ul class="pricing-features">
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M5 13l4 4L19 7" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <strong>Không giới hạn</strong> bài viết
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M5 13l4 4L19 7" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            8 framework viết bài
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M5 13l4 4L19 7" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Tạo meta SEO nâng cao
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M5 13l4 4L19 7" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Viết lại đoạn văn (5 tone)
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M5 13l4 4L19 7" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Lên lịch bài viết
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M5 13l4 4L19 7" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Hỗ trợ ưu tiên
          </li>
        </ul>
        <a href="/login" class="btn btn-primary" style="width: 100%; justify-content: center;">
          Mua ngay
        </a>
      </div>

      <!-- Yearly -->
      <div class="pricing-card">
        <div class="pricing-header">
          <h3>Pro Yearly</h3>
          <div class="price">
            <span class="amount">1.490.000đ</span>
            <span class="period">/năm</span>
          </div>
          <p class="pricing-save">Tiết kiệm 38%</p>
        </div>
        <ul class="pricing-features">
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M5 13l4 4L19 7" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <strong>Không giới hạn</strong> bài viết
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M5 13l4 4L19 7" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Tất cả tính năng Pro
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M5 13l4 4L19 7" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            2 tháng miễn phí
          </li>
        </ul>
        <a href="/login" class="btn btn-secondary" style="width: 100%; justify-content: center;">
          Mua năm
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .pricing-card {
    background: white;
    border-radius: var(--radius);
    border: 1px solid var(--gray-200);
    padding: 32px;
    position: relative;
    transition: box-shadow 0.2s;
  }

  .pricing-card:hover {
    box-shadow: var(--shadow-lg);
  }

  .pricing-pro {
    border: 2px solid var(--primary);
    box-shadow: 0 0 0 4px rgb(99 102 241 / 0.1);
  }

  .pricing-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--primary);
    color: white;
    padding: 4px 16px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
  }

  .pricing-header h3 {
    font-size: 20px;
    font-weight: 700;
    color: var(--gray-900);
    margin-bottom: 16px;
  }

  .price {
    margin-bottom: 8px;
  }

  .price .amount {
    font-size: 32px;
    font-weight: 800;
    color: var(--gray-900);
  }

  .price .period {
    font-size: 16px;
    color: var(--gray-400);
  }

  .pricing-desc {
    font-size: 14px;
    color: var(--gray-500);
    margin-bottom: 24px;
  }

  .pricing-save {
    font-size: 14px;
    color: var(--success);
    font-weight: 600;
    margin-bottom: 24px;
  }

  .pricing-features {
    list-style: none;
    margin-bottom: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pricing-features li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--gray-700);
  }

  .pricing-features li.disabled {
    color: var(--gray-400);
  }

  .pricing-features li strong {
    color: var(--gray-900);
  }

  @media (max-width: 900px) {
    .pricing-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
    }
  }
</style>
