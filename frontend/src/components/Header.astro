---
// Header - always shows login button on server side (auth is client-side)
---

<nav class="nav" id="mainNav">
  <div class="container">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="28" height="28" rx="8" fill="#6366f1"/>
          <path d="M8 10h12M8 14h8M8 18h10" stroke="white" stroke-width="2" stroke-linecap="round"/>
        </svg>
        ContentAI
      </a>

      <div class="nav-links">
        <a href="#features" class="btn btn-secondary" style="padding: 8px 16px; font-size: 14px;">Tính năng</a>
        <a href="#pricing" class="btn btn-secondary" style="padding: 8px 16px; font-size: 14px;">Bảng giá</a>
        <a href="#download" class="btn btn-secondary" style="padding: 8px 16px; font-size: 14px;">Tải về</a>
      </div>

      <!-- Always show login on server - updated client-side -->
      <div class="nav-user" id="navUser">
        <a href="/login" class="btn btn-google" style="padding: 8px 20px; font-size: 14px; width: auto;" id="navLoginBtn">
          <svg width="18" height="18" viewBox="0 0 24 24">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Đăng nhập Google
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  import PocketBase from 'pocketbase';

  const pb = new PocketBase('https://8qj9xau0f6ama5b.591p.pocketbasecloud.com');
  const navUser = document.getElementById('navUser')!;

  function renderLoggedIn(user: any) {
    navUser.innerHTML = `
      <span class="badge badge-free">Free</span>
      <div class="nav-avatar">
        ${user?.avatar ? `<img src="${user.avatar}" alt="${user.email}" />` : (user?.email?.charAt(0).toUpperCase() || 'U')}
      </div>
      <span style="font-size: 14px; color: var(--gray-600); margin-right: 8px;">${user?.email || ''}</span>
      <button id="logoutBtn" class="btn btn-secondary" style="padding: 6px 14px; font-size: 13px; border: 1px solid var(--gray-300);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
          <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Đăng xuất
      </button>
    `;

    // Attach logout handler
    document.getElementById('logoutBtn')?.addEventListener('click', () => {
      pb.authStore.clear();
      window.location.href = '/';
    });
  }

  function renderLoggedOut() {
    navUser.innerHTML = `
      <a href="/login" class="btn btn-google" style="padding: 8px 20px; font-size: 14px; width: auto;">
        <svg width="18" height="18" viewBox="0 0 24 24">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Đăng nhập Google
      </a>
    `;
  }

  // Check auth status and update UI
  if (pb.authStore.isValid) {
    renderLoggedIn(pb.authStore.model);
  }

  // Listen for auth changes
  pb.authStore.onChange(() => {
    if (pb.authStore.isValid) {
      renderLoggedIn(pb.authStore.model);
    } else {
      renderLoggedOut();
    }
  });
</script>
