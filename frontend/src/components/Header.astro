---
// Header - always shows login button on server side (auth is client-side)
---

<nav class="nav" id="mainNav">
  <div class="container">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="28" height="28" rx="8" fill="#15211b" />
          <path d="M8 10h12M8 14h8M8 18h10" stroke="#FFF8EF" stroke-width="2" stroke-linecap="round" />
        </svg>
        ContentAI
      </a>

      <div class="nav-links">
        <a href="/#features" class="nav-link">Tính năng</a>
        <a href="/#pricing" class="nav-link">Bảng giá</a>
        <a href="/#download" class="nav-link">Tải về</a>
      </div>

      <button
        type="button"
        class="nav-toggle"
        id="navToggle"
        aria-label="Mở menu"
        aria-expanded="false"
        aria-controls="navPanel"
      >
        <span></span>
        <span></span>
      </button>

      <div class="nav-user" id="navUser">
        <a href="/login" class="btn btn-google nav-login">
          <svg width="18" height="18" viewBox="0 0 24 24">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
          </svg>
          Đăng nhập Google
        </a>
      </div>
    </div>

    <div class="nav-panel" id="navPanel">
      <div class="nav-panel-links">
        <a href="/#features" class="nav-panel-link">Tính năng</a>
        <a href="/#pricing" class="nav-panel-link">Bảng giá</a>
        <a href="/#download" class="nav-panel-link">Tải về</a>
        <a href="/dashboard" class="nav-panel-link">Dashboard</a>
      </div>
      <div class="nav-panel-auth" id="navMobileAuth">
        <a href="/login" class="btn btn-google nav-mobile-login">
          <svg width="18" height="18" viewBox="0 0 24 24">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
          </svg>
          Đăng nhập Google
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  import { createPocketBaseClient, syncPocketBaseCookie } from '../lib/pocketbase.ts';
  import { runtimeConfig } from '../lib/runtime.ts';

  const pb = createPocketBaseClient(runtimeConfig.pbUrl);
  const navUser = document.getElementById('navUser')!;
  const navToggle = document.getElementById('navToggle') as HTMLButtonElement | null;
  const navPanel = document.getElementById('navPanel');
  const navMobileAuth = document.getElementById('navMobileAuth');

  function setPanelOpen(nextOpen: boolean) {
    if (!navToggle || !navPanel) return;
    navToggle.setAttribute('aria-expanded', nextOpen ? 'true' : 'false');
    navPanel.dataset.open = nextOpen ? 'true' : 'false';
  }

  function syncAuthCookie() {
    syncPocketBaseCookie(pb);
  }

  function buildLoginLink(extraClass = '') {
    const link = document.createElement('a');
    link.href = '/login';
    link.className = `btn btn-google ${extraClass}`.trim();
    link.innerHTML = `
      <svg width="18" height="18" viewBox="0 0 24 24">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Đăng nhập Google
    `;
    return link;
  }

  async function resolveTierLabel() {
    if (!pb.authStore.isValid) return null;
    try {
      const result = await pb.collection('user_domains').getList(1, 50, {
        filter: `user = "${pb.authStore.record?.id}"`,
        fields: 'domain,license_key,tier',
      });

      if (result.items.length === 0) return 'Free';

      const statuses = await Promise.all(
        result.items.map(async (item) => {
          try {
            const res = await fetch(`${runtimeConfig.apiUrl}/license/status`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                domain: item.domain,
                key: item.license_key || '',
              }),
            });

            if (!res.ok) return null;
            return await res.json();
          } catch {
            return null;
          }
        }),
      );

      const anyResolved = statuses.some(Boolean);
      if (anyResolved) {
        return statuses.some((item) => item?.isPro === true) ? 'Pro' : 'Free';
      }

      return result.items.some((item) => item.tier === 'pro') ? 'Pro' : 'Free';
    } catch {
      return null;
    }
  }

  async function renderUI() {
    navUser.replaceChildren();
    navMobileAuth?.replaceChildren();

    if (!pb.authStore.isValid) {
      navUser.appendChild(buildLoginLink('nav-login'));
      navMobileAuth?.appendChild(buildLoginLink('nav-mobile-login'));
      return;
    }

    syncAuthCookie();

    const user = pb.authStore.record;
    const avatar = user?.avatar;
    const avatarUrl = avatar && !avatar.startsWith('http')
      ? `${runtimeConfig.pbUrl}/api/files/_pb_users_auth_/${user?.id}/${avatar}`
      : avatar;

    const badge = document.createElement('span');
    const tier = await resolveTierLabel();
    badge.className = `badge ${tier === 'Pro' ? 'badge-pro' : 'badge-free'}`;
    badge.textContent = tier || 'Tài khoản';

    const avatarWrap = document.createElement('div');
    avatarWrap.className = 'nav-avatar';
    if (avatarUrl) {
      const image = document.createElement('img');
      image.src = avatarUrl;
      image.alt = user?.email || '';
      avatarWrap.appendChild(image);
    } else {
      avatarWrap.textContent = (user?.email || 'U').charAt(0).toUpperCase();
    }

    const email = document.createElement('span');
    email.className = 'nav-email';
    email.textContent = user?.email || '';

    const logoutBtn = document.createElement('button');
    logoutBtn.className = 'btn btn-secondary';
    logoutBtn.style.padding = '10px 16px';
    logoutBtn.style.fontSize = '13px';
    logoutBtn.innerHTML = `
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
        <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Đăng xuất
    `;
    logoutBtn.addEventListener('click', () => {
      pb.authStore.clear();
      syncAuthCookie();
      setPanelOpen(false);
      window.location.href = '/';
    });

    navUser.append(badge, avatarWrap, email, logoutBtn);

    if (navMobileAuth) {
      const mobileWrap = document.createElement('div');
      mobileWrap.className = 'nav-mobile-user';

      const mobileMeta = document.createElement('div');
      mobileMeta.className = 'nav-mobile-meta';

      const mobileBadge = badge.cloneNode(true) as HTMLElement;
      const mobileEmail = document.createElement('div');
      mobileEmail.className = 'nav-mobile-email';
      mobileEmail.textContent = user?.email || '';
      mobileMeta.append(mobileBadge, mobileEmail);

      const dashboardLink = document.createElement('a');
      dashboardLink.href = '/dashboard';
      dashboardLink.className = 'btn btn-primary nav-mobile-dashboard';
      dashboardLink.textContent = 'Mở Dashboard';

      const mobileLogout = logoutBtn.cloneNode(true) as HTMLButtonElement;
      mobileLogout.addEventListener('click', () => {
        pb.authStore.clear();
        syncAuthCookie();
        setPanelOpen(false);
        window.location.href = '/';
      });

      mobileWrap.append(mobileMeta, dashboardLink, mobileLogout);
      navMobileAuth.appendChild(mobileWrap);
    }
  }

  navToggle?.addEventListener('click', () => {
    const nextOpen = navToggle.getAttribute('aria-expanded') !== 'true';
    setPanelOpen(nextOpen);
  });

  navPanel?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      setPanelOpen(false);
    });
  });

  renderUI();

  pb.authStore.onChange(() => {
    renderUI();
  });
</script>

<style is:global>
  .nav {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 18px 0;
    backdrop-filter: blur(18px);
    background: rgb(255 252 245 / 0.72);
    border-bottom: 1px solid rgb(21 33 27 / 0.08);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 16px 20px;
    border-radius: 999px;
    border: 1px solid rgb(21 33 27 / 0.08);
    background: rgb(255 255 255 / 0.6);
    box-shadow: 0 12px 30px rgb(21 33 27 / 0.06);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nav-link {
    padding: 10px 14px;
    border-radius: 999px;
    color: var(--ink-800);
    font-size: 14px;
    font-weight: 600;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .nav-link:hover {
    background: rgb(15 118 110 / 0.08);
    color: var(--primary-dark);
    text-decoration: none;
  }

  .nav-user {
    display: flex;
    align-items: center;
    gap: 10px;
    min-height: 42px;
  }

  .nav-toggle {
    display: none;
    width: 44px;
    height: 44px;
    border: 1px solid rgb(21 33 27 / 0.1);
    background: rgb(255 255 255 / 0.82);
    border-radius: 16px;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
  }

  .nav-toggle span {
    width: 16px;
    height: 2px;
    border-radius: 999px;
    background: var(--ink-950);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .nav-login {
    width: auto;
    padding: 10px 18px;
    font-size: 14px;
  }

  .nav-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary) 0%, #4aa799 100%);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    font-weight: 700;
    font-family: 'Space Grotesk', sans-serif;
  }

  .nav-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .nav-email {
    font-size: 14px;
    color: var(--ink-700);
    max-width: 180px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .nav-panel {
    display: none;
  }

  @media (max-width: 900px) {
    .nav-links {
      display: none;
    }

    .nav-toggle {
      display: inline-flex;
    }

    .nav-user {
      display: none;
    }

    .nav-inner {
      padding: 14px 16px;
    }

    .nav-panel {
      display: grid;
      gap: 14px;
      margin-top: 12px;
      padding: 18px;
      border-radius: 28px;
      border: 1px solid rgb(21 33 27 / 0.08);
      background: rgb(255 255 255 / 0.76);
      box-shadow: var(--shadow);
      opacity: 0;
      transform: translateY(-8px);
      pointer-events: none;
      transition: opacity 0.2s ease, transform 0.2s ease;
    }

    .nav-panel[data-open='true'] {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    .nav-panel-links {
      display: grid;
      gap: 8px;
    }

    .nav-panel-link {
      padding: 12px 14px;
      border-radius: 16px;
      background: rgb(247 242 233 / 0.72);
      color: var(--ink-900);
      font-size: 15px;
      font-weight: 600;
    }

    .nav-panel-link:hover {
      text-decoration: none;
      background: rgb(215 244 239 / 0.46);
    }

    .nav-mobile-login,
    .nav-mobile-dashboard {
      width: 100%;
    }

    .nav-mobile-user {
      display: grid;
      gap: 12px;
    }

    .nav-mobile-meta {
      display: grid;
      gap: 8px;
      padding: 14px;
      border-radius: 18px;
      background: rgb(247 242 233 / 0.72);
    }

    .nav-mobile-email {
      font-size: 14px;
      color: var(--ink-700);
      word-break: break-word;
    }

    .nav-toggle[aria-expanded='true'] span:first-child {
      transform: translateY(3.5px) rotate(45deg);
    }

    .nav-toggle[aria-expanded='true'] span:last-child {
      transform: translateY(-3.5px) rotate(-45deg);
    }
  }

  @media (max-width: 620px) {
    .nav-email {
      display: none;
    }

    .nav {
      padding: 12px 0;
    }
  }
</style>
