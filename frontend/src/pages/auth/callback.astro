---
// PocketBase OAuth callback — runs in SDK popup window
// SDK handles token exchange internally, syncs auth to opener, then closes popup
const error = Astro.url.searchParams.get('error');
const errorDesc = Astro.url.searchParams.get('error_description');

if (error) {
  return Astro.redirect('/login?error=' + encodeURIComponent(errorDesc || error));
}
---

<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Đang đăng nhập...</title>
</head>
<body>
  <p style="font-family: system-ui; text-align: center; margin-top: 100px; color: #4b5563;">Hoàn tất đăng nhập...</p>
  <script>
    // SDK handles token exchange in this popup window, syncs auth to opener.
    // Once auth is synced, close the popup — opener page will redirect.
    window.addEventListener('load', () => {
      setTimeout(() => {
        if (window.opener) {
          window.close();
        } else {
          window.location.href = '/dashboard';
        }
      }, 500);
    });
  </script>
</body>
</html>
