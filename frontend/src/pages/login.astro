---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const PB_URL = 'https://8qj9xau0f6ama5b.591p.pocketbasecloud.com';
const redirectUrl = Astro.url.origin + '/auth/callback';
const googleAuthUrl = `${PB_URL}/api/auth-providers/google-oauth2/connect/google?redirectTo=${encodeURIComponent(redirectUrl)}`;
---

<Layout title="Đăng nhập - ContentAI" description="Đăng nhập vào ContentAI để quản lý license và tải plugin.">
  <Header />

  <section class="login-section">
    <div class="login-card">
      <div class="login-header">
        <h1>Chào mừng bạn</h1>
        <p>Đăng nhập để quản lý license và tải plugin</p>
      </div>

      <a href={googleAuthUrl} class="btn btn-google" style="padding: 14px 24px; font-size: 16px;">
        <svg width="20" height="20" viewBox="0 0 24 24">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Đăng nhập với Google
      </a>

      <div class="login-divider">
        <span>hoặc</span>
      </div>

      <p style="text-align: center; color: var(--gray-500); font-size: 14px;">
        Bạn chưa có tài khoản? Đăng nhập Google sẽ tự động tạo tài khoản cho bạn.
      </p>

      <div class="login-features">
        <div class="login-feature">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path d="M5 13l4 4L19 7" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Miễn phí 5 bài/tháng</span>
        </div>
        <div class="login-feature">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path d="M5 13l4 4L19 7" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Tải plugin WordPress</span>
        </div>
        <div class="login-feature">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path d="M5 13l4 4L19 7" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Quản lý license key</span>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .login-section {
    min-height: calc(100vh - 72px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 24px;
    background: linear-gradient(180deg, #ffffff 0%, #f9fafb 100%);
  }

  .login-card {
    background: white;
    border-radius: var(--radius);
    border: 1px solid var(--gray-200);
    padding: 48px;
    max-width: 420px;
    width: 100%;
    box-shadow: var(--shadow-lg);
  }

  .login-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .login-header h1 {
    font-size: 28px;
    font-weight: 800;
    color: var(--gray-900);
    margin-bottom: 8px;
  }

  .login-header p {
    font-size: 15px;
    color: var(--gray-500);
  }

  .login-divider {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 24px 0;
  }

  .login-divider::before,
  .login-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--gray-200);
  }

  .login-divider span {
    font-size: 13px;
    color: var(--gray-400);
  }

  .login-features {
    margin-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: var(--gray-50);
    padding: 20px;
    border-radius: 12px;
  }

  .login-feature {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--gray-700);
  }
</style>
