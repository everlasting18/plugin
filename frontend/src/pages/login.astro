---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Đăng nhập - ContentAI" description="Đăng nhập vào ContentAI để quản lý license và tải plugin.">
  <Header />

  <section class="login-section">
    <div class="login-card">
      <div class="login-chip">Access Console</div>
      <div class="login-header">
        <h1>Đăng nhập để mở workspace ContentAI</h1>
        <p>Quản lý website, quota miễn phí và license Pro từ một dashboard duy nhất.</p>
      </div>

      <button id="googleLoginBtn" class="btn btn-google" style="padding: 14px 24px; font-size: 16px;">
        <svg width="20" height="20" viewBox="0 0 24 24">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
        </svg>
        <span id="btnText">Đăng nhập với Google</span>
      </button>

      <div id="errorMsg" class="alert alert-error" style="display: none; margin-top: 16px;"></div>

      <div class="login-divider">
        <span>hoặc</span>
      </div>

      <p class="login-note">
        Bạn chưa có tài khoản? Đăng nhập Google sẽ tự động tạo tài khoản cho bạn.
      </p>

      <div class="login-features">
        <div class="login-feature">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path d="M5 13l4 4L19 7" stroke="#1f9d74" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>Miễn phí 5 bài mỗi tháng</span>
        </div>
        <div class="login-feature">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path d="M5 13l4 4L19 7" stroke="#1f9d74" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>Tải plugin WordPress</span>
        </div>
        <div class="login-feature">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path d="M5 13l4 4L19 7" stroke="#1f9d74" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>Quản lý license key</span>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { createPocketBaseClient, syncPocketBaseCookie } from '../lib/pocketbase.ts';
  import { runtimeConfig } from '../lib/runtime.ts';

  const pb = createPocketBaseClient(runtimeConfig.pbUrl);

  const googleBtn = document.getElementById('googleLoginBtn') as HTMLButtonElement;
  const btnText = document.getElementById('btnText') as HTMLSpanElement;
  const errorMsg = document.getElementById('errorMsg') as HTMLDivElement;

  function syncAuthCookie() {
    syncPocketBaseCookie(pb);
  }

  if (pb.authStore.isValid) {
    syncAuthCookie();
    window.location.href = '/dashboard';
  }

  googleBtn.addEventListener('click', async () => {
    googleBtn.disabled = true;
    btnText.textContent = 'Đang đăng nhập...';
    errorMsg.style.display = 'none';

    try {
      await pb.collection('users').authWithOAuth2({
        provider: 'google',
      });
      syncAuthCookie();
      window.location.href = '/dashboard';
    } catch (err: any) {
      if (err?.isAbort) {
        btnText.textContent = 'Đăng nhập với Google';
        googleBtn.disabled = false;
        return;
      }
      const msg = err?.message || 'Không thể đăng nhập. Vui lòng thử lại.';
      errorMsg.textContent = msg;
      errorMsg.style.display = 'block';
      btnText.textContent = 'Đăng nhập với Google';
      googleBtn.disabled = false;
    }
  });
</script>

<style>
  .login-section {
    min-height: calc(100vh - 72px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 24px;
    background:
      radial-gradient(circle at top left, rgb(15 118 110 / 0.1), transparent 24%),
      radial-gradient(circle at bottom right, rgb(219 122 57 / 0.14), transparent 26%),
      linear-gradient(180deg, #fffefb 0%, #f7f2e9 100%);
  }

  .login-card {
    background: rgb(255 255 255 / 0.76);
    border-radius: 32px;
    border: 1px solid rgb(21 33 27 / 0.08);
    padding: 48px;
    max-width: 440px;
    width: 100%;
    box-shadow: var(--shadow-lg);
    backdrop-filter: blur(16px);
  }

  .login-chip {
    display: inline-flex;
    margin-bottom: 18px;
    padding: 9px 14px;
    border-radius: 999px;
    background: var(--accent-soft);
    color: #905022;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .login-header {
    text-align: left;
    margin-bottom: 32px;
  }

  .login-header h1 {
    font-size: 34px;
    font-weight: 700;
    color: var(--ink-950);
    margin-bottom: 8px;
    line-height: 1.02;
  }

  .login-header p {
    font-size: 15px;
    color: var(--ink-700);
  }

  .login-divider {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 24px 0;
  }

  .login-divider::before,
  .login-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgb(21 33 27 / 0.08);
  }

  .login-divider span {
    font-size: 13px;
    color: var(--ink-600);
  }

  .login-note {
    text-align: center;
    color: var(--ink-700);
    font-size: 14px;
  }

  .login-features {
    margin-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: rgb(247 242 233 / 0.88);
    padding: 20px;
    border-radius: 22px;
    border: 1px solid rgb(21 33 27 / 0.08);
  }

  .login-feature {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--ink-800);
  }
</style>
