# Editor directories
.vscode/
.idea/
*.swp
*.swo

# Track these directories
!api/
!api/src/
!api/pb_migrations/
!frontend/
!wp-content/plugins/

# Ignore specific files at root
.DS_Store
.htaccess
wp-config.php
wp-config-local.php
error_log
php_errorlog
*.log
*.log.*

# Ignore WP core
wp-admin/
wp-includes/
wp-content/themes/
wp-content/uploads/
wp-content/cache/
*.php
*.txt
*.xml
*.html
license.txt
readme.html
my-first-plugin/

# Track specific file types in tracked dirs
!api/**/*.ts
!api/**/*.js
!api/**/*.json
!wp-content/plugins/contentai-plugin/**/*.php
!wp-content/plugins/contentai-plugin/**/*.jsx
!wp-content/plugins/contentai-plugin/**/*.js
!wp-content/plugins/contentai-plugin/**/*.css
!wp-content/plugins/contentai-plugin/**/*.module.css
!wp-content/plugins/contentai-plugin/**/*.svg
!wp-content/plugins/contentai-plugin/**/*.png
!wp-content/plugins/contentai-plugin/**/*.jpg
!frontend/src/**/*
!frontend/public/**/*
!frontend/astro.config.mjs
!frontend/package.json
!frontend/tsconfig.json
!frontend/README.md
!frontend/.gitignore
!frontend/scripts/**/*

# Inside plugins: ignore build artifacts
wp-content/plugins/contentai-plugin/node_modules/
wp-content/plugins/contentai-plugin/dist/
wp-content/plugins/contentai-plugin/.vite/
wp-content/plugins/contentai-plugin/*.log
wp-content/plugins/contentai-plugin/package-lock.json

# API-specific ignores
api/.env
api/.DS_Store
api/*.log
api/app.log
api/licenses.json
api/usage.json
api/deno.lock
api/node_modules/

# API PB migrations - keep only schema files
api/pb_migrations/*.json
api/pb_migrations/*.ts
!api/pb_migrations/1_licenses.json
!api/pb_migrations/2_usage.json
!api/pb_migrations/3_usage_logs.json
!api/pb_migrations/sync_to_pb.ts
api/pb_migrations/demo_license.json
api/pb_migrations/1700000000_init.js

# Frontend build artifacts
frontend/node_modules/
frontend/dist/
frontend/.astro/
frontend/.env
frontend/package-lock.json
